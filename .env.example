# 환경변수 안내
#
# .env        — 공개 가능한 값만 (커밋됨). Firebase 웹 구성값 등.
# .env.local  — 비밀 값 (커밋 안 됨). 이 파일을 복사해 만드세요.
#
# 배포 환경(Cloudflare Workers)에서는 .env.local 대신
# Worker의 런타임 Variables and Secrets에 비밀 값을 등록해야 합니다.

# --- .env에 넣을 공개 값 ---
# Firebase 웹 앱 구성 (모듈 9 클라우드 DB 체험용)
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# --- .env.local / 플랫폼 Secret에 넣을 비밀 값 ---

# Module 8 PRD 점검·업그레이드용 AI — 서버 전용, 절대 VITE_ 접두사 금지
#
# [배포: Cloudflare Secret] GCP_SERVICE_ACCOUNT — GCP 서비스 계정 키 JSON 전체.
#   Vertex AI(aiplatform)를 사용 — 호출자 지역 검사가 없어 Cloudflare Worker에서도 안정적.
#   (서비스 계정에 roles/aiplatform.user 역할 + aiplatform API 활성화 필요)
# GCP_SERVICE_ACCOUNT=""
#
# [로컬 개발용] GCP_SERVICE_ACCOUNT가 없으면 GEMINI_API_KEY(AI Studio)로 동작.
GEMINI_API_KEY=""
# GEMINI_MODEL 미설정 시 코드 기본값 gemini-2.5-flash-lite 사용.
GEMINI_MODEL="gemini-2.5-flash-lite"
