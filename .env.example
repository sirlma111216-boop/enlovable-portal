# 환경변수 안내
#
# .env        — 공개 가능한 값만 (커밋됨). Supabase publishable/anon 키 등.
# .env.local  — 비밀 값 (커밋 안 됨). 이 파일을 복사해 만드세요.
#
# 배포 환경(Cloudflare Workers 등)에서는 .env.local 대신
# 플랫폼의 Variables & Secrets에 아래 비밀 값을 등록해야 합니다.

# --- .env.local에 넣을 비밀 값 ---

# Module 8 PRD 점검·업그레이드용 AI — 서버 전용, 절대 VITE_ 접두사 금지
#
# [배포: Cloudflare Secret] GCP_SERVICE_ACCOUNT — GCP 서비스 계정 키 JSON 전체.
#   Vertex AI(aiplatform)를 사용 — AI Studio API와 달리 호출자 지역 검사가 없어
#   Cloudflare Worker에서도 안정적으로 동작합니다.
#   (서비스 계정에 roles/aiplatform.user 역할 필요)
# GCP_SERVICE_ACCOUNT=""
#
# [로컬 개발용] GCP_SERVICE_ACCOUNT가 없으면 GEMINI_API_KEY(AI Studio)로 동작.
GEMINI_API_KEY=""
# GEMINI_MODEL 미설정 시 코드 기본값 gemini-2.5-flash-lite 사용.
GEMINI_MODEL="gemini-2.5-flash-lite"

# (선택) Module 9 데모 참가자 조회 서버 함수용 — Supabase service role 키
# SUPABASE_SERVICE_ROLE_KEY=""
