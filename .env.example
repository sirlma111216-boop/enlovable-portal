# 이 파일을 .env로 복사한 뒤 실제 값을 채워 넣으세요.
# .env는 .gitignore에 포함되어 있어 커밋되지 않습니다.

# Supabase (공개 가능한 publishable/anon 키)
SUPABASE_PROJECT_ID=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_URL=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# 외부 Gemini API (Module 8 PRD 점검·업그레이드용)
# 서버에서만 사용 — 절대 VITE_ 접두사를 붙이지 마세요.
# 없으면 Lovable Cloud 배포 시 내장 AI Gateway(LOVABLE_API_KEY)로 자동 폴백합니다.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"
